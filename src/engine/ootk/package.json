{
  "name": "ootk",
  "version": "7.0.3",
  "type": "module",
  "description": "Orbital Object Toolkit including Multiple Propagators, Initial Orbit Determination, and Maneuver Calculations.",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/main.cjs",
      "default": "./dist/main.js"
    }
  },
  "main": "dist/main.cjs",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "bench": "npm run build && node benchmark/run.mjs",
    "bench:only": "node benchmark/run.mjs",
    "build": "tsup",
    "changelog": "auto-changelog",
    "clean": "node ./scripts/cleanup.mjs",
    "circular": "node scripts/check-circular.mjs",
    "circular:list": "madge --circular --extensions ts src/main.ts",
    "circular:image": "madge --circular --image circular-deps.svg --extensions ts src/main.ts",
    "lint": "npx eslint src",
    "lint:fix": "npx eslint src --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "npm run build && vitest run --config test/integration/vitest.config.mts",
    "test:integration:only": "vitest run --config test/integration/vitest.config.mts",
    "test:all": "npm run test && npm run test:integration",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "prepublishOnly": "npm run test:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thkruz/ootk.git"
  },
  "keywords": [
    "space",
    "sgp4",
    "orbit",
    "toolkit",
    "satellite",
    "radar",
    "iod"
  ],
  "author": "Theodore Kruczek <theodore.kruczek@gmail.com> (https://github.com/ootk/)",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/thkruz/ootk/issues"
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.18",
    "astronomy-engine": "^2.1.19",
    "auto-changelog": "^2.5.0",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "madge": "^8.0.0",
    "satellite.js": "^7.0.1",
    "semantic-release": "^25.0.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.0.18"
  },
  "homepage": "https://github.com/thkruz/ootk"
}
