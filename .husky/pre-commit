#!/usr/bin/env sh

# Lint only the staged files (lint-staged); config lives in package.json.
# Bypass for temporary work with: git commit --no-verify
npx lint-staged || {
  echo "" >&2
  echo "SatGlobe uses pre-commit hooks to run lint on staged files so PRs pass" >&2
  echo "CI the first time. Skip temporarily with: git commit --no-verify" >&2
  exit 1
}
